# Supabase 配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 可选：直连 PostgreSQL（用于 npm run db:cleanup-consumptions 等脚本）
# Supabase Dashboard -> Project Settings -> Database -> Connection string（URI）
# DATABASE_URL=postgresql://postgres.[ref]:[数据库密码]@db.xxx.supabase.co:5432/postgres

# 龙猫服务器配置
TOTORO_API_URL=https://app.xtotoro.com/app
TOTORO_USER_AGENT=TotoroSchool/1.2.14 (iPhone; iOS 17.4.1; Scale/3.00)

# Token 验证控制（仅本地/测试环境使用）
# 设置为 'true' 或 '1' 可跳过龙猫 Token 验证
# 适用于龙猫服务器维护期间或 Token 验证出现问题的临时解决方案
# SKIP_TOKEN_VERIFY=true

# 服务配置
PORT=3005
NODE_ENV=production

# 海外服务器配置
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
