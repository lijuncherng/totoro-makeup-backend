{
  "name": "totoro-makeup-backend",
  "version": "1.0.0",
  "packageManager": "pnpm@9.15.9",
  "description": "海外补跑后端服务 - 使用 Supabase + Cloudflare Workers",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:local": "tsx watch src/index.ts",
    "build": "node build.mjs && echo 'Build complete!'",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:cleanup-consumptions": "tsx scripts/run-cleanup-consumptions.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "hono": "^4.0.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.11.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2",
    "wrangler": "^3.0.0"
  }
}
